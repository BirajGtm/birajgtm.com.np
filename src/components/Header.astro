---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.jsx";

// Check if we're on the homepage
const isHomepage = Astro.url.pathname === "/";
---

<header
  class="fixed top-0 inset-x-0 z-50 w-full backdrop-blur-md bg-white/70 dark:bg-darkBg/70 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300"
>
  <nav class="max-w-6xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- LOGO -->
      <a
        href="/"
        class="text-xl font-bold text-slate-900 dark:text-white hover:text-primary transition-colors"
      >
        Biraj Gautam
      </a>

      <!-- DESKTOP NAV -->
      <div class="hidden md:flex items-center gap-6">
        <HeaderLink href="/">Home</HeaderLink>
        {
          isHomepage && (
            <>
              <HeaderLink href="#skills">Skills</HeaderLink>
              <HeaderLink href="#experience">Experience</HeaderLink>
              <HeaderLink href="#certifications">Certifications</HeaderLink>
            </>
          )
        }
        <HeaderLink href="/projects">Projects</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
      </div>

      <!-- SEPARATOR -->
      <div class="hidden md:block w-px h-6 bg-slate-300 dark:bg-slate-700">
      </div>

      <!-- THEME TOGGLE -->
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
