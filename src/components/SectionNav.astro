---
const sections = [
  { name: "Skills", href: "#skills" },
  { name: "Experience", href: "#experience" },
  { name: "Certifications", href: "#certifications" },
  { name: "Projects", href: "#projects" },
  { name: "Blog", href: "#blog" },
];
---

<nav
  class="sticky top-16 z-40 bg-white/80 dark:bg-darkBg/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 shadow-sm"
>
  <div class="max-w-5xl mx-auto px-4">
    <ul class="flex gap-1 overflow-x-auto py-3 scrollbar-hide">
      {
        sections.map((section) => (
          <li>
            <a
              href={section.href}
              class="inline-block px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors whitespace-nowrap"
            >
              {section.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
