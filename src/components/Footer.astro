---
/**
 * SITE FOOTER COMPONENT
 * Displays copyright info and social media profiles.
 * Dynamic: Automatically updates the current year.
 * Style: Uses a clean, centered layout with consistent icon spacing.
 */
import data from '../data/portfolio.json';
const today = new Date();
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-darkBg mt-auto transition-colors duration-300">
	<div class="max-w-5xl mx-auto px-4 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
		
		<!-- COPYRIGHT & STATUS -->
		<div class="text-center md:text-left">
			<p class="text-slate-500 dark:text-slate-400 text-sm mb-2">
				&copy; {today.getFullYear()} {data.basics.name}. All rights reserved.
			</p>
			
			<!-- IT "System Status" Vibe -->
			<div class="inline-flex items-center gap-2 px-2 py-1 rounded-full bg-green-100 dark:bg-green-900/30 border border-green-200 dark:border-green-800">
				<span class="relative flex h-2 w-2">
				  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
				  <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
				</span>
				<span class="text-xs font-medium text-green-700 dark:text-green-400">All Systems Operational</span>
			</div>
		</div>

		<!-- SOCIAL LINKS (From JSON) -->
		<div class="flex gap-6">
			{data.socials.map((social) => (
				<a 
					href={social.url} 
					target="_blank" 
					class="text-slate-400 hover:text-primary dark:hover:text-primary transition-colors"
					aria-label={`Follow on ${social.network}`}
				>
					<span class="sr-only">{social.network}</span>
					<!-- Simple Text Fallback if icon font fails, or you can add SVG icons here later -->
					<span class="font-bold text-sm">{social.network}</span>
				</a>
			))}
		</div>
	</div>
</footer>