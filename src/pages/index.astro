---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.jsx';
import InteractiveList from '../components/InteractiveList.jsx';
import data from '../data/portfolio.json';
import details from '../data/details.json';
import { getCollection } from 'astro:content';

// 1. Fetch Blog Posts (Sort by newest)
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

// 2. Helper to attach HTML content to JSON items
function enhanceData(items) {
    if (!items) return [];
    return items.map((item) => {
        if (item.detailId && details[item.detailId]) {
            const detailContent = details[item.detailId];
            return { ...item, html: detailContent.content };
        }
        return item;
    });
}

// 3. Create the final data objects for React
const enhancedWork = enhanceData(data.work);
const enhancedEducation = enhanceData(data.education);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${data.basics.name} | ${data.basics.role}`} description={data.basics.tagline} />
	</head>
	<body class="bg-white dark:bg-darkBg text-slate-900 dark:text-slate-200 font-sans transition-colors duration-300 flex flex-col min-h-screen">
		<Header />
		
		<main class="flex-grow">
			
			<!-- =========================================
			     HERO SECTION
			     ========================================= -->
			<section class="max-w-5xl mx-auto px-4 py-20 md:py-28">
				<div class="grid md:grid-cols-3 gap-12 items-start">
					<div class="md:col-span-2 space-y-6">
						<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-600 dark:text-slate-300 w-fit">
							<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
							{data.basics.status}
						</div>
						<h1 class="text-5xl md:text-6xl font-bold tracking-tight text-slate-900 dark:text-white">
							{data.basics.name}
						</h1>
						<h2 class="text-2xl md:text-3xl text-primary font-medium">
							{data.basics.role} <span class="text-slate-400 dark:text-slate-500">&</span> {data.basics.subRole}
						</h2>
						<p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl">
							{data.basics.tagline}
						</p>
						<div class="flex flex-wrap gap-4 pt-4">
							<a href="/resume.pdf" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-600 transition-colors shadow-lg shadow-blue-500/20">Download CV</a>
							<a href="/projects" class="border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-300 px-6 py-3 rounded-lg font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">View Projects</a>
						</div>
					</div>
					<!-- Terminal Graphic -->
					<div class="hidden md:block bg-slate-900 rounded-xl p-6 shadow-2xl border border-slate-800 font-mono text-sm transform rotate-1 hover:rotate-0 transition-transform duration-500">
						<div class="flex gap-2 mb-4 opacity-50"><div class="w-3 h-3 rounded-full bg-red-500"></div><div class="w-3 h-3 rounded-full bg-yellow-500"></div><div class="w-3 h-3 rounded-full bg-green-500"></div></div>
						<div class="space-y-2">
							<div class="flex gap-2"><span class="text-green-400">➜</span><span class="text-blue-400">~</span><span class="text-slate-400">whoami</span></div>
							<div class="text-white pl-4">"{data.basics.role}"</div>
							<div class="flex gap-2 mt-4"><span class="text-green-400">➜</span><span class="text-blue-400">~</span><span class="text-slate-400">uptime</span></div>
							<div class="text-yellow-300 pl-4">4+ Years Experience</div>
						</div>
					</div>
				</div>
			</section>

			<!-- =========================================
			     SKILLS
			     ========================================= -->
			<section class="bg-slate-50 dark:bg-slate-800/50 border-y border-slate-200 dark:border-slate-800">
				<div class="max-w-5xl mx-auto px-4 py-16">
					<h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-8">Technical Competencies</h3>
					<div class="grid md:grid-cols-2 gap-8">
						{data.skills.map((category) => (
							<div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm">
								<h4 class="text-lg font-semibold mb-4 text-slate-900 dark:text-white flex items-center gap-2">
									{category.category === "Infrastructure" ? "🏢" : "⚡"} {category.category}
								</h4>
								<div class="flex flex-wrap gap-2">
									{category.items.map((skill) => (
										<span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-medium rounded-md border border-slate-200 dark:border-slate-700">{skill.name}</span>
									))}
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- =========================================
			     PROFESSIONAL TIMELINE (Interactive)
			     ========================================= -->
			<section class="max-w-4xl mx-auto px-4 py-20">
				
				<!-- 1. EXPERIENCE -->
				<div class="mb-20">
					<h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-10 flex items-center gap-3">
						<span class="text-primary">💼</span> Professional Experience
					</h2>
					<!-- React Component handles the click & modal -->
					<InteractiveList client:load items={enhancedWork} type="work" />
				</div>

				<!-- 2. EDUCATION -->
				<div class="mb-20">
					<h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-10 flex items-center gap-3">
						<span class="text-primary">🎓</span> Education
					</h2>
					<!-- React Component handles the click & modal -->
					<InteractiveList client:load items={enhancedEducation} type="education" />
				</div>

				<!-- 3. CERTIFICATIONS -->
				<div>
					<h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-10 flex items-center gap-3">
						<span class="text-primary">📜</span> Certifications
					</h2>
					
					<div class="flex flex-col gap-4">
						{data.certs.map((cert) => (
							<a 
								href={cert.url} 
								target="_blank"
								class="group flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 hover:border-primary hover:shadow-lg transition-all duration-300 relative overflow-hidden"
							>
								<!-- Hover Effect Background -->
								<div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>

								<!-- Icon / Issuer Badge -->
								<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 group-hover:scale-105 transition-transform z-10">
									<span class="text-2xl">
										{cert.issuer.includes('Microsoft') ? '🟦' : 
										 cert.issuer.includes('Cisco') ? '📡' : 
										 cert.issuer.includes('Fortinet') ? '🛡️' : 
										 '🏅'}
									</span>
								</div>

								<!-- Content -->
								<div class="flex-grow min-w-0 z-10">
									<h3 class="text-base md:text-lg font-bold text-slate-900 dark:text-white truncate group-hover:text-primary transition-colors">
										{cert.name}
									</h3>
									<div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
										<span>{cert.issuer}</span>
										<span class="w-1 h-1 rounded-full bg-slate-300"></span>
										<span>{cert.date}</span>
									</div>
								</div>

								<!-- Verify Action -->
								<div class="hidden sm:flex items-center gap-1 text-xs font-bold text-primary opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300 z-10">
									VERIFY <span>↗</span>
								</div>
								<div class="sm:hidden text-slate-300 group-hover:text-primary z-10">↗</div>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- =========================================
			     PROJECTS
			     ========================================= -->
			<section class="bg-slate-50 dark:bg-slate-800/50 border-y border-slate-200 dark:border-slate-800">
				<div class="max-w-5xl mx-auto px-4 py-20">
					<div class="flex items-center justify-between mb-12">
						<h2 class="text-3xl font-bold text-slate-900 dark:text-white">Featured Projects</h2>
						<a href="/projects" class="hidden md:inline-flex text-primary font-medium hover:underline">View All →</a>
					</div>
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
						{data.projects.map((project) => (
							<ProjectCard client:visible {...project} />
						))}
					</div>
				</div>
			</section>

			<!-- =========================================
			     LATEST BLOG POSTS (New Premium Design)
			     ========================================= -->
			<section class="max-w-5xl mx-auto px-4 py-20">
				<div class="flex items-center justify-between mb-8">
					<h2 class="text-2xl font-bold text-slate-900 dark:text-white">Latest Documentation</h2>
					<a href="/blog" class="text-primary hover:underline">Read Blog →</a>
				</div>
				<div class="grid md:grid-cols-3 gap-6">
					{posts.map((post) => (
						<a href={`/blog/${post.slug}/`} class="group relative flex flex-col h-full bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 p-6 hover:shadow-2xl hover:border-primary/30 hover:-translate-y-1 transition-all duration-300 overflow-hidden">
							
							<!-- 1. Gradient Overlay (Appears on Hover) -->
							<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

							<!-- 2. Header: Date & Icon -->
							<div class="relative flex items-center justify-between mb-4 z-10">
								<span class="text-xs font-mono font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded border border-slate-200 dark:border-slate-700 group-hover:border-primary/30 transition-colors">
									{post.data.pubDate.toLocaleDateString()}
								</span>
								
								<!-- Document Icon -->
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-300 dark:text-slate-600 group-hover:text-primary transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
									<polyline points="14 2 14 8 20 8"/>
								</svg>
							</div>

							<!-- 3. Content -->
							<div class="relative flex-grow z-10">
								<h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3 group-hover:text-primary transition-colors leading-tight">
									{post.data.title}
								</h3>
								<p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 leading-relaxed mb-6">
									{post.data.description}
								</p>
							</div>

							<!-- 4. Footer: 'Read Article' Link -->
							<div class="relative mt-auto flex items-center text-primary font-bold text-sm z-10">
								Read Article 
								<span class="ml-2 transform group-hover:translate-x-1 transition-transform duration-300">→</span>
							</div>
						</a>
					))}
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>