---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import CommentBox from "../components/CommentBox.jsx";

type Props = CollectionEntry<"projects">["data"];

const {
    title,
    description,
    heroImage,
    stack,
    repoUrl,
    liveUrl,
    role,
    timeline,
} = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }
            .project-container {
                display: grid;
                grid-template-columns: 1fr;
                gap: 2rem;
                max-width: 1200px;
                margin: 0 auto;
                padding: 2em 1em;
            }
            @media (min-width: 768px) {
                .project-container {
                    grid-template-columns: 300px 1fr;
                }
            }
            .hero-image {
                width: 100%;
                margin-bottom: 2rem;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
                width: 100%;
                height: auto;
            }
            .dynamic-card {
                width: 100%;
                height: 300px;
                background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                gap: 1rem;
                box-shadow: var(--box-shadow);
            }
            .dynamic-card-icon {
                font-size: 4rem;
                color: #333;
            }
            .sidebar {
                background: #f9f9f9;
                padding: 1.5rem;
                border-radius: 8px;
                height: fit-content;
                position: sticky;
                top: 2rem;
            }
            .sidebar-item {
                margin-bottom: 1.5rem;
            }
            .sidebar-label {
                font-weight: bold;
                display: block;
                margin-bottom: 0.5rem;
                color: #555;
                font-size: 0.9rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }
            .sidebar-value {
                font-size: 1rem;
                color: #222;
            }
            .stack-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
            }
            .stack-tag {
                background: #e0e0e0;
                padding: 0.25rem 0.5rem;
                border-radius: 4px;
                font-size: 0.85rem;
            }
            .project-links {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }
            .btn {
                display: inline-block;
                padding: 0.5rem 1rem;
                background: #333;
                color: #fff;
                text-decoration: none;
                border-radius: 4px;
                text-align: center;
                transition: background 0.2s;
            }
            .btn:hover {
                background: #555;
            }
            .btn-outline {
                background: transparent;
                border: 1px solid #333;
                color: #333;
            }
            .btn-outline:hover {
                background: #333;
                color: #fff;
            }
            .prose {
                max-width: 100%;
                color: rgb(var(--gray-dark));
            }
            .title {
                margin-bottom: 1em;
                padding: 1em 0;
                line-height: 1;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
                font-size: 2.5rem;
            }
            .related-content {
                margin-top: 4rem;
                padding-top: 2rem;
                border-top: 1px solid #eee;
            }
            .related-content h3 {
                margin-bottom: 1rem;
            }
            .related-links {
                list-style: none;
                padding: 0;
            }
            .related-links li {
                margin-bottom: 0.5rem;
            }
            .related-links a {
                color: #333;
                text-decoration: none;
            }
            .related-links a:hover {
                text-decoration: underline;
            }
        </style>
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "SoftwareSourceCode",
                name: title,
                description: description,
                programmingLanguage: stack,
                author: {
                    "@type": "Person",
                    name: "Biraj Gautam",
                },
                codeRepository: repoUrl,
            })}
        />
    </head>

    <body>
        <Header />
        <main>
            <div class="project-container">
                <aside class="sidebar">
                    {
                        role && (
                            <div class="sidebar-item">
                                <span class="sidebar-label">Role</span>
                                <div class="sidebar-value">{role}</div>
                            </div>
                        )
                    }
                    {
                        timeline && (
                            <div class="sidebar-item">
                                <span class="sidebar-label">Timeline</span>
                                <div class="sidebar-value">{timeline}</div>
                            </div>
                        )
                    }
                    <div class="sidebar-item">
                        <span class="sidebar-label">Tech Stack</span>
                        <div class="stack-tags">
                            {
                                stack.map((tech: string) => (
                                    <span class="stack-tag">{tech}</span>
                                ))
                            }
                        </div>
                    </div>
                    {
                        (repoUrl || liveUrl) && (
                            <div class="sidebar-item">
                                <span class="sidebar-label">Links</span>
                                <div class="project-links">
                                    {liveUrl && (
                                        <a
                                            href={liveUrl}
                                            target="_blank"
                                            class="btn"
                                        >
                                            View Live
                                        </a>
                                    )}
                                    {repoUrl && (
                                        <a
                                            href={repoUrl}
                                            target="_blank"
                                            class="btn btn-outline"
                                        >
                                            View Code
                                        </a>
                                    )}
                                </div>
                            </div>
                        )
                    }
                </aside>

                <article>
                    <div class="hero-image">
                        {
                            heroImage ? (
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt=""
                                />
                            ) : (
                                <div class="dynamic-card">
                                    <div class="dynamic-card-icon">🚀</div>
                                    <h3>{title}</h3>
                                </div>
                            )
                        }
                    </div>
                    <div class="prose">
                        <div class="title">
                            <h1>{title}</h1>
                            <p>{description}</p>
                            <hr />
                        </div>
                        <slot />

                        <div class="related-content">
                            <h3>Related Blog Posts</h3>
                            <ul class="related-links">
                                {
                                    /* Placeholder for related content logic - would typically filter blog posts by matching tags */
                                }
                                <li>
                                    <a href="/blog"
                                        >Check out my latest blog posts</a
                                    >
                                </li>
                            </ul>
                        </div>

                        <div
                            class="comments-section"
                            style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #eee;"
                        >
                            <h3>Comments</h3>
                            <CommentBox
                                client:visible
                                projectId="5701842210127872-proj"
                                boxId="project-commentbox"
                            />
                        </div>
                    </div>
                </article>
            </div>
        </main>
        <Footer />
    </body>
</html>
